    def list_peers(self):
        silent_handler.set_silent(False)
        if not self.network:
            print("❌ Network not initialized!")
            return
        
        with self.network.peer_lock:
            peers = list(self.network.peers.values())
        
        print("\n📋 CONNECTED PEERS:")
        print("-"*50)
        
        if not peers:
            print("   No connected peers")
            return
        
        for i, peer in enumerate(peers, 1):
            status = "✅" if peer.connected else "❌"
            last_msg = datetime.fromtimestamp(peer.last_message).strftime('%H:%M:%S')
            print(f"{i}. {status} {peer.address[0]}:{peer.address[1]} - Last: {last_msg}")
        
        input("\nPress Enter to continue...")
    
    def add_peer_manual(self):
        silent_handler.set_silent(False)
        if not self.network:
            print("❌ Network not initialized!")
            return
        
        peer_input = input("Peer address (ip:port): ").strip()
        
        if not peer_input:
            print("❌ Address cannot be empty!")
            return
        
        if ':' in peer_input:
            ip, port_str = peer_input.split(':', 1)
            try:
                port = int(port_str)
            except ValueError:
                print("❌ Invalid port number!")
                return
        else:
            ip = peer_input
            port = Config.P2P_PORT
        
        print(f"Connecting to {ip}:{port}...")
        if self.network.connect_to_peer(ip, port):
            print(f"✅ Connected to peer {ip}:{port}")
        else:
            print(f"❌ Failed to connect to {ip}:{port}")
    
    def disconnect_peer(self):
        silent_handler.set_silent(False)
        if not self.network:
            print("❌ Network not initialized!")
            return
        
        with self.network.peer_lock:
            peers = list(self.network.peers.values())
        
        if not peers:
            print("❌ No connected peers!")
            return
        
        print("\nSelect peer to disconnect:")
        for i, peer in enumerate(peers, 1):
            status = "✅" if peer.connected else "❌"
            print(f"{i}. {status} {peer.address[0]}:{peer.address[1]}")
        
        try:
            selection = int(input(f"\nSelect (1-{len(peers)}): "))
            if 1 <= selection <= len(peers):
                peer = peers[selection - 1]
                peer.close()
                print(f"✅ Disconnected from {peer.address[0]}:{peer.address[1]}")
            else:
                print("❌ Invalid selection!")
        except ValueError:
            print("❌ Invalid input!")
    
    def request_blocks(self):
        silent_handler.set_silent(False)
        if not self.network:
            print("❌ Network not initialized!")
            return
        
        with self.network.peer_lock:
            peers = list(self.network.peers.values())
        
        if not peers:
            print("❌ No connected peers!")
            return
        
        print(f"\nRequesting blocks from peers...")
        for peer in peers:
            if peer.connected:
                self.network.request_blocks(peer, self.blockchain.height + 1)
                print(f"✅ Requested blocks from {peer.address[0]}:{peer.address[1]}")
                break
        
        input("\nPress Enter to continue...")
    
    def request_peer_list(self):
        silent_handler.set_silent(False)
        if not self.network:
            print("❌ Network not initialized!")
            return
        
        with self.network.peer_lock:
            peers = list(self.network.peers.values())
        
        if not peers:
            print("❌ No connected peers to request from!")
            return
        
        for peer in peers[:3]:
            if peer.connected:
                getpeers_msg = {
                    'type': NetworkMessage.GET_PEERS.value,
                    'data': {}
                }
                peer.send(getpeers_msg)
        
        print("✅ Peer list requests sent")
        input("\nPress Enter to continue...")
    
    def manual_dns_query(self):
        silent_handler.set_silent(False)
        print("\n🔍 Querying DNS seeds...")
