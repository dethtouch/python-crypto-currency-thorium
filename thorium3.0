            print(f"   Total Peers: {total_peers}")
            
            print("\nOptions:")
            print("1. List connected peers")
            print("2. Add peer manually")
            print("3. Disconnect from peer")
            print("4. Request blocks from peers")
            print("5. Request peer list")
            print("6. Query DNS seeds")
            print("7. Network statistics")
            print("8. Back to main menu")
            
            choice = input("\nSelect option: ").strip()
