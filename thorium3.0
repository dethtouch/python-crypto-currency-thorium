            self.database_maintenance()
        elif choice == "3":
            self.reset_utxo_cache()
        elif choice == "4":
            return
        else:
            print("❌ Invalid option!")
    
    def view_configuration(self):
        silent_handler.set_silent(False)
        print("\n⚙️  CONFIGURATION")
        print("="*50)
        print(f"Transaction Fee: 0 TH (Zero)")
        print(f"Easy Difficulty: {Config.EASY_DIFFICULTY} zeros")
        print(f"Hard Difficulty: {Config.HARD_DIFFICULTY} zeros")
        print(f"Difficulty Change: Block {Config.DIFFICULTY_CHANGE_HEIGHT:,}")
        print(f"Initial Reward: {format_thorium(Config.INITIAL_REWARD)} TH")
        print(f"Minimum Reward: {format_thorium(Config.MIN_REWARD)} TH")
        print(f"P2P Port: {Config.P2P_PORT}")
        print(f"Max Peers: {Config.MAX_PEERS}")
        
        input("\nPress Enter to continue...")
    
    def reset_utxo_cache(self):
        silent_handler.set_silent(False)
        print("🔄 Reloading UTXO cache...")
        self.blockchain.utxo_cache.clear()
        self.blockchain.utxo_set.clear()
        self.blockchain.load_utxo_set()
        print(f"✅ UTXO cache reloaded: {len(self.blockchain.utxo_set)} UTXOs")
    
    def show_wallet_details(self):
        silent_handler.set_silent(False)
        if not self.wallet_manager.current_wallet:
            print("❌ No wallet selected!")
            return
        
        wallet = self.wallet_manager.current_wallet
        balance = self.wallet_manager.get_balance(wallet.address)
        
        print(f"\n👛 WALLET DETAILS")
        print("="*50)
        print(f"Name: {wallet.name}")
        print(f"Address: {wallet.address}")
        print(f"Balance: {format_thorium(balance)} TH")
        
        input("\nPress Enter to continue...")
    
    def show_public_key(self):
        silent_handler.set_silent(False)
        if not self.wallet_manager.current_wallet:
            print("❌ No wallet selected!")
            return
        
        wallet = self.wallet_manager.current_wallet
        
        print(f"\n🔑 PUBLIC KEY for {wallet.name}")
        print("-"*40)
        print(wallet.public_key)
        print("-"*40)
        
        input("\nPress Enter to continue...")
    
    def show_private_key(self):
        silent_handler.set_silent(False)
        if not self.wallet_manager.current_wallet:
            print("❌ No wallet selected!")
            return
        
        wallet = self.wallet_manager.current_wallet
        
        print(f"\n🔐 PRIVATE KEY for {wallet.name}")
        print("!"*60)
        print("⚠️  EXTREME CAUTION: Never share your private key!")
        print("!"*60)
        
        password = input("\nEnter password to confirm: ").strip()
        
        private_key = self.wallet_manager.get_private_key(wallet.address, password)
        
        if private_key:
            print(f"\nPrivate Key:")
            print("-"*40)
            print(private_key)
            print("-"*40)
        else:
            print("❌ Incorrect password!")
        
        input("\nPress Enter to continue...")
    
    def show_utxos(self):
        silent_handler.set_silent(False)
        if not self.wallet_manager.current_wallet:
            print("❌ No wallet selected!")
            return
        
        wallet = self.wallet_manager.current_wallet
        utxos = self.blockchain.get_utxos_for_address(wallet.address)
        
        print(f"\n🔍 UTXOs for {wallet.address}")
        print("="*60)
        
        if not utxos:
            print("   No UTXOs found")
            return
        
        total = Decimal('0')
        for i, utxo in enumerate(utxos[:10], 1):
            print(f"{i}. TXID: {utxo.txid[:16]}... - {format_thorium(utxo.amount)} TH")
            total += utxo.amount
        
        print("-"*40)
        print(f"Total: {format_thorium(total)} TH in {len(utxos)} UTXOs")
        
        input("\nPress Enter to continue...")
    
    def database_maintenance(self):
        silent_handler.set_silent(False)
        print("\n🛠️  DATABASE MAINTENANCE")
        print("\nOptions:")
        print("1. Compact database")
        print("2. Check integrity")
        print("3. Back")
        
        choice = input("\nSelect option: ").strip()
        
        if choice == "1":
            print("🗜️  Compacting database...")
            self.blockchain.db.execute("VACUUM")
            self.blockchain.db.commit()
            print("✅ Database compacted")
        elif choice == "2":
            print("🔍 Checking integrity...")
            cursor = self.blockchain.db.execute("PRAGMA integrity_check")
            result = cursor.fetchone()
            if result and result[0] == 'ok':
                print("✅ Database integrity: OK")
            else:
                print(f"❌ Database integrity check failed: {result}")

# --- MAIN ENTRY POINT ---
def main():
    """Main entry point"""
    silent_handler.set_silent(False)  # Show initial messages
    print("\n" + "="*70)
    print("🚀 STARTING THORIUM 2.0 WITH P2P NETWORKING")
    print("="*70)
    print("🌟 Features: Zero Transaction Fees | Dynamic Difficulty | Block Syncing")
    print(f"   First {Config.DIFFICULTY_CHANGE_HEIGHT:,} blocks: {Config.EASY_DIFFICULTY} zeros difficulty")
    print(f"   After {Config.DIFFICULTY_CHANGE_HEIGHT:,} blocks: {Config.HARD_DIFFICULTY} zeros difficulty")
    print(f"   Block reward: Halving until {format_thorium(Config.MIN_REWARD)} TH, then permanent")
    print("🔒 UTXO Verification: Enabled - Prevents Double Spending")
    print("🔇 Silent Mode: Background messages suppressed during menu interaction")
    print("="*70)
    
    try:
        app = ThoriumApp()
        app.initialize()
        
        print("🔄 Starting P2P network...")
        print("💡 Tip: Background operations run silently. Check logs for details.")
        time.sleep(1)
        
        app.main_menu()
        
    except KeyboardInterrupt:
        print("\n\n👋 Goodbye!")
    except Exception as e:
        logger.error(f"Fatal error: {e}", exc_info=True)
        print(f"\n❌ Fatal error: {e}")
        print("Check logs for details")

if __name__ == "__main__":
    main()
