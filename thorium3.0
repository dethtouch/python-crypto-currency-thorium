            if choice == "1":
                self.list_peers()
            elif choice == "2":
                self.add_peer_manual()
            elif choice == "3":
                self.disconnect_peer()
            elif choice == "4":
                self.request_blocks()
            elif choice == "5":
                self.request_peer_list()
            elif choice == "6":
