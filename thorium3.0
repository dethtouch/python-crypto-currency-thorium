    # P2P Network configuration
    PEER_DISCOVERY_INTERVAL = 300  # seconds - increased to 5 minutes
    PING_INTERVAL = 30  # seconds
    MAX_MESSAGE_SIZE = 10 * 1024 * 1024  # 10MB
    MANUAL_MODE = False  # Set to False for automatic connections
    
    # UI Configuration
    SILENT_MODE = True  # Suppress background messages during menu interaction
    
    @classmethod
    def validate(cls):
        """Validate all configuration values"""
        assert cls.THORIUM_PRECISION > 0, "Precision must be positive"
        assert cls.MIN_THORIUM_AMOUNT > Decimal('0'), "Min amount must be positive"
        assert cls.MAX_THORIUM_SUPPLY > Decimal('0'), "Max supply must be positive"
        assert cls.EASY_DIFFICULTY > 0, "Easy difficulty must be positive"
        assert cls.HARD_DIFFICULTY > 0, "Hard difficulty must be positive"
        assert cls.DIFFICULTY_CHANGE_HEIGHT > 0, "Difficulty change height must be positive"
        assert cls.BLOCK_TIME_TARGET > 0, "Block time must be positive"
        assert cls.INITIAL_REWARD > Decimal('0'), "Reward must be positive"
        assert cls.HALVING_INTERVAL > 0, "Halving interval must be positive"
        assert cls.MIN_REWARD > Decimal('0'), "Minimum reward must be positive"
        assert cls.MAX_BLOCK_SIZE > 0, "Block size must be positive"
        assert cls.P2P_PORT > 0 and cls.P2P_PORT < 65536, "Invalid port"
        return True

# Validate configuration
Config.validate()

