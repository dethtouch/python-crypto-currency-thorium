    PRECISION = Decimal('28')
    THORIUM_PRECISION = 8
    MIN_THORIUM_AMOUNT = Decimal('0.00000001')  # 1 Satoshi equivalent
    MAX_THORIUM_SUPPLY = Decimal('2100000000')
    
    # Mining configuration - Dynamic difficulty based on block height
    EASY_DIFFICULTY = 4      # First 100k blocks: 4 hex zeros
    HARD_DIFFICULTY = 6      # After 100k blocks: 6 hex zeros
    DIFFICULTY_CHANGE_HEIGHT = 100000  # Change after 100,000 blocks
    
    BLOCK_TIME_TARGET = 60  # seconds
    INITIAL_REWARD = Decimal('50.0')
    HALVING_INTERVAL = 210000
    MIN_REWARD = Decimal('1.0')  # Minimum reward after halvings
    MAX_BLOCK_SIZE = 1024 * 1024  # 1MB
    MINING_THREADS = 2
    
    # Network configuration
    P2P_PORT = 9333
    API_PORT = 9334
    MAX_PEERS = 100
    CONNECTION_TIMEOUT = 15
    PEER_BROADCAST_INTERVAL = 300
    
    # DNS Seeds for peer discovery
    DNS_SEEDS = [
        "seed.thorium.network",
        "dnsseed.thorium.org",
        "seed.thorium.io",
        "thorium.dnsseed.net"
    ]
    
    # Fallback hardcoded nodes (used if DNS fails)
    FALLBACK_NODES = [
        ("192.168.0.26", 9333), #the OG node
    ]
    
    # DNS servers for redundant queries
    DNS_SERVERS = [
        "8.8.8.8",      # Google
        "1.1.1.1",      # Cloudflare
        "9.9.9.9",      # Quad9
        "208.67.222.222", # OpenDNS
    ]
    
    # Transaction configuration - Set fees to 0
    TRANSACTION_FEE = Decimal('0.0000')
    MIN_RELAY_FEE = Decimal('0.00000')
    MAX_TRANSACTIONS_PER_BLOCK = 2000
    MAX_MEMPOOL_SIZE = 10000
    
    # Security configuration
    MAX_SIGNATURE_CHECKS = 1000
    PASSWORD_MIN_LENGTH = 8
    KEY_DERIVATION_ITERATIONS = 100000
    ENCRYPTION_VERSION = "AES-256-GCM"
    
    # Database configuration
    DATABASE_FILE = "thorium.db"
    WALLETS_DIR = "wallets/"
    BLOCKCHAIN_DIR = "blocks/"
